# Auto-detect text files and normalize to LF in the repo.
* text=auto

# Shell scripts run on Linux / the Pi — keep them LF everywhere,
# regardless of any machine's core.autocrlf setting.
*.sh        text eol=lf
*.bash      text eol=lf

# Extension-less scripts.
infocat-pi  text eol=lf

# Library/config that gets sourced.
*.ps1       text eol=crlf

# Treat common binaries as binary (no EOL munging).
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.pdf       binary
*.mkv       binary
*.mp4       binary
*.m2ts      binary
