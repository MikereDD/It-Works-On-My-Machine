#!/usr/bin/env bash

SESSION="arakiel"

# If session exists → attach
tmux has-session -t $SESSION 2>/dev/null
if [ $? -eq 0 ]; then
    exec tmux attach -t $SESSION
fi

# Create session
tmux new-session -d -s $SESSION -n main

# ── Window 1: core workspace ───────────────
tmux send-keys -t $SESSION:1 "cd ~" C-m

# Split layout:
# ┌──────────────┬──────────────┐
# │ main shell   │ logs         │
# │              ├──────────────┤
# │              │ monitor      │
# └──────────────┴──────────────┘

tmux split-window -h -t $SESSION:1
tmux split-window -v -t $SESSION:1.2

# Left pane → working shell
tmux send-keys -t $SESSION:1.1 "clear" C-m

# Top-right → logs
tmux send-keys -t $SESSION:1.2 "tail -f /var/log/pironman5/main.log" C-m

# Bottom-right → system monitor
tmux send-keys -t $SESSION:1.3 "htop" C-m

# ── Window 2: bots ─────────────────────────
tmux new-window -t $SESSION:2 -n bots
tmux send-keys -t $SESSION:2 "cd ~/bots" C-m

# Example bot launch (adjust later)
tmux send-keys -t $SESSION:2 "ls" C-m

# ── Window 3: scratch ──────────────────────
tmux new-window -t $SESSION:3 -n scratch
tmux send-keys -t $SESSION:3 "cd ~" C-m

# Go back to main window
tmux select-window -t $SESSION:1

# Attach
exec tmux attach -t $SESSION
