#--------------------------------------------

# ── Git branch helper ──────────────────────
git_branch() {
    git branch --show-current 2>/dev/null | awk 'NF {print " (" $1 ")"}'
}

# ── Prompt ────────────────────────────────

if [[ -n "$SSH_CLIENT" || -n "$SSH_TTY" ]]; then
    # SSH session (slightly marked)
    PS1='\[\e[0;96m\]┌─[\[\e[0;31m\]SSH\[\e[0;96m\]]-[\[\e[0;92m\]\u@\h \[\e[0;37m\]\W\[\e[0;96m\]$(git_branch)\[\e[0;96m\]]\n\[\e[0;96m\]└─╼\[\e[0m\] '
else
    # Local session (clean)
    PS1='\[\e[0;96m\]┌─[\[\e[0;92m\]\u@\h \[\e[0;37m\]\W\[\e[0;96m\]$(git_branch)\[\e[0;96m\]]\n\[\e[0;96m\]└─╼\[\e[0m\] '
fi
