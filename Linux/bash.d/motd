#!/usr/bin/env bash
#--------------------------------------------
# file:     ~/.bash.d/motd
# author:   Mike Redd
# version:  2.3
# desc:     Custom login message for SSH sessions (Unicode borders)
#--------------------------------------------

# Only show for SSH logins (not physical console)
if [ -n "$SSH_CONNECTION" ]; then

    # Colors
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    MAGENTA='\033[0;35m'
    CYAN='\033[0;36m'
    WHITE='\033[1;37m'
    BOLD='\033[1m'
    NC='\033[0m'

    # System stats
    LOAD=$(cat /proc/loadavg | awk '{print $1", "$2", "$3}')
    MEM=$(free -h | awk '/^Mem:/ {print $3"/"$2}')
    DISK=$(df -h / | awk 'NR==2 {print $3"/"$2 " ("$5")"}')
    TEMP=$(cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null | awk '{printf "%.1f°C", $1/1000}')
    UPTIME=$(uptime -p | sed 's/up //')
    SESSIONS=$(who | wc -l)
    PACKAGES=$(pacman -Q 2>/dev/null | wc -l)

    # UFW Status (check iptables chains)
    if sudo iptables -L INPUT 2>/dev/null | grep -q "ufw-before-input"; then
        UFW_STATUS="Active"
        UFW_ICON="${GREEN}[+]${NC}"
        UFW_COLOR=$GREEN
    else
        UFW_STATUS="Inactive"
        UFW_ICON="${RED}[!]${NC}"
        UFW_COLOR=$RED
    fi

    # SSHGuard Status
    if systemctl is-active --quiet sshguard 2>/dev/null; then
        SG_STATUS="Active"
        SG_ICON="${GREEN}[+]${NC}"
        SG_COLOR=$GREEN
    else
        SG_STATUS="Inactive"
        SG_ICON="${RED}[!]${NC}"
        SG_COLOR=$RED
    fi

    # Header
    echo ""
    echo -e "${BOLD}${MAGENTA}┌──────────────────────────────────────────────────────────────────┐${NC}"
    echo -e "${BOLD}${MAGENTA}│                                                                  │${NC}"
    echo -e "${BOLD}${MAGENTA}│${NC}              ${BOLD}${WHITE}WELCOME TO ARAKIEL${NC}  ${BOLD}${MAGENTA}                                │${NC}"
    echo -e "${BOLD}${MAGENTA}│${NC}              ${CYAN}Raspberry Pi 5 | Arch Linux${NC}                     ${BOLD}${MAGENTA}│${NC}"
    echo -e "${BOLD}${MAGENTA}│                                                                  │${NC}"
    echo -e "${BOLD}${MAGENTA}└──────────────────────────────────────────────────────────────────┘${NC}"
    echo ""

    # System Info
    echo -e "${BOLD}${CYAN}┌──────────────────────────────────────────────────────────────────┐${NC}"
    echo -e "${BOLD}${CYAN}│${NC}  ${BOLD}SYSTEM INFORMATION${NC}                                                  ${BOLD}${CYAN}│${NC}"
    echo -e "${BOLD}${CYAN}├──────────────────────────────────────────────────────────────────┤${NC}"
    printf "${CYAN}│${NC}  ${GREEN}Hostname${NC}        ${WHITE}%-43s${NC}  ${CYAN}│${NC}\n" "$HOSTNAME"
    printf "${CYAN}│${NC}  ${GREEN}Kernel${NC}          ${WHITE}%-43s${NC}  ${CYAN}│${NC}\n" "$(uname -r)"
    printf "${CYAN}│${NC}  ${GREEN}Uptime${NC}          ${WHITE}%-43s${NC}  ${CYAN}│${NC}\n" "$UPTIME"
    printf "${CYAN}│${NC}  ${GREEN}Load Avg${NC}        ${WHITE}%-43s${NC}  ${CYAN}│${NC}\n" "$LOAD"
    printf "${CYAN}│${NC}  ${GREEN}Memory${NC}          ${WHITE}%-43s${NC}  ${CYAN}│${NC}\n" "$MEM"
    printf "${CYAN}│${NC}  ${GREEN}Disk (root)${NC}     ${WHITE}%-43s${NC}  ${CYAN}│${NC}\n" "$DISK"
    printf "${CYAN}│${NC}  ${GREEN}CPU Temp${NC}        ${WHITE}%-43s${NC}  ${CYAN}│${NC}\n" "$TEMP"
    printf "${CYAN}│${NC}  ${GREEN}Packages${NC}        ${WHITE}%-43s${NC}  ${CYAN}│${NC}\n" "$PACKAGES"
    printf "${CYAN}│${NC}  ${GREEN}Sessions${NC}        ${WHITE}%-43s${NC}  ${CYAN}│${NC}\n" "$SESSIONS"
    echo -e "${BOLD}${CYAN}└──────────────────────────────────────────────────────────────────┘${NC}"
    echo ""

    # Security Status
    echo -e "${BOLD}${YELLOW}┌──────────────────────────────────────────────────────────────────┐${NC}"
    echo -e "${BOLD}${YELLOW}│${NC}  ${BOLD}SECURITY STATUS${NC}                                                 ${BOLD}${YELLOW}│${NC}"
    echo -e "${BOLD}${YELLOW}├──────────────────────────────────────────────────────────────────┤${NC}"
    echo -e "${YELLOW}│${NC}  ${UFW_ICON} UFW                     ${UFW_COLOR}UFW: $UFW_STATUS${NC}                                          ${YELLOW}│${NC}"
    echo -e "${YELLOW}│${NC}  ${SG_ICON} SSHGuard                ${SG_COLOR}SSHGuard: $SG_STATUS${NC}                                    ${YELLOW}│${NC}"
    echo -e "${YELLOW}│${NC}  ${GREEN}[+]${NC} SSH Keys                ${GREEN}Password auth: disabled${NC}                                    ${YELLOW}│${NC}"
    echo -e "${BOLD}${YELLOW}└──────────────────────────────────────────────────────────────────┘${NC}"
    echo ""

    # Quick Commands
    echo -e "${BOLD}${GREEN}┌──────────────────────────────────────────────────────────────────┐${NC}"
    echo -e "${BOLD}${GREEN}│${NC}  ${BOLD}QUICK COMMANDS${NC}                                                 ${BOLD}${GREEN}│${NC}"
    echo -e "${BOLD}${GREEN}├──────────────────────────────────────────────────────────────────┤${NC}"
    echo -e "${GREEN}│${NC}  ${WHITE}tools${NC}      → Tool menu                                      ${GREEN}│${NC}"
    echo -e "${GREEN}│${NC}  ${WHITE}rp5si${NC}      → Full system info                             ${GREEN}│${NC}"
    echo -e "${GREEN}│${NC}  ${WHITE}pifw${NC}       → Firewall manager                             ${GREEN}│${NC}"
    echo -e "${GREEN}│${NC}  ${WHITE}ff${NC}         → Fast system info (fastfetch)                 ${GREEN}│${NC}"
    echo -e "${GREEN}│${NC}  ${WHITE}update${NC}      → System update (pacman -Syu)                  ${GREEN}│${NC}"
    echo -e "${GREEN}│${NC}  ${WHITE}tmuxaa${NC}     → Attach to arakiel tmux session               ${GREEN}│${NC}"
    echo -e "${BOLD}${GREEN}└──────────────────────────────────────────────────────────────────┘${NC}"
    echo ""
fi
